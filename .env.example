# --- DOCKER CONFIGURATION ---
DOMAIN_NAME="example.com"
TRAEFIK_ACME_EMAIL="your-email@example.com"
# Generate with: echo $(htpasswd -nB user) | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_AUTH="admin:$$2y$$05$$vI.3H0.B/4.U56.7890123456789012345678901234567890"

# Database Configuration (Docker)
POSTGRES_USER="grhb_user"
POSTGRES_PASSWORD="grhb_password"
POSTGRES_DB="grhb_db"

# Database URL for local development (outside Docker)
# Example for PostgreSQL: postgresql://user:password@localhost:5432/dbname?schema=public
DATABASE_URL="postgresql://grhb_user:grhb_password@localhost:5432/grhb_db?schema=public"

# --- APPLICATION CONFIGURATION ---
# Authentication
# At least 32 characters for NUXT_SESSION_PASSWORD
NUXT_SESSION_PASSWORD=""

# OVHcloud IAM SSO Configuration
OVH_APP_KEY="your_ovh_app_key_here"
OVH_APP_SECRET="your_ovh_app_secret_here"
# Comma-separated list of OVH NIC handles allowed to log in (e.g. ab123-ovh,xy456-ovh)
NUXT_OVH_ALLOWED_NIC_HANDLES="handle1-ovh,handle2-ovh"

# Email Configuration
EMAIL_HOST=""
EMAIL_PORT="465"
EMAIL_USER=""
EMAIL_PASSWORD=""

# External Services
FACEBOOK_RSS=""
